{
  "name": "scrumws-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ScrumWS运行看板 · 桌面端（Electron）",
  "author": "zzusp <peng_zzu@163.com>",
  "type": "module",
  "main": "electron/main.js",
  "engines": { "node": ">=20.11" },
  "scripts": {
    "start": "electron .",
    "start:web": "node platform/standalone.js",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.zzusp.scrumws-desktop",
    "productName": "ScrumWS",
    "asar": false,
    "files": ["electron/**", "platform/**", "package.json"],
    "directories": { "output": "dist" },
    "win": { "target": ["nsis"] },
    "nsis": { "oneClick": true, "perMachine": false }
  }
}
