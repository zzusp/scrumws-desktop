{
  "name": "scrumws-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ScrumWS 任务看板 · 桌面端（Electron）",
  "author": "zzusp <peng_zzu@163.com>",
  "type": "module",
  "main": "electron/main.js",
  "bin": { "scrumws-task": "platform/cli.js" },
  "engines": { "node": ">=20.11" },
  "scripts": {
    "start": "electron .",
    "start:web": "node platform/standalone.js",
    "task": "node platform/cli.js",
    "dist": "electron-builder --win",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.zzusp.scrumws-desktop",
    "productName": "ScrumWS",
    "asar": false,
    "files": ["electron/**", "platform/**", "build/icon.png", "package.json"],
    "directories": { "output": "dist" },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": { "oneClick": true, "perMachine": false },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  }
}
